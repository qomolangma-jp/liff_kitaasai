// ====================================================================
// ⚠️ 設定箇所: ご自身の情報に置き換えてください
// ====================================================================

// 1. LINE公式アカウントの「チャネルアクセストークン」
const LINE_CHANNEL_ACCESS_TOKEN = getRequiredScriptProperty('LINE_CHANNEL_ACCESS_TOKEN');

// ★追加：LINE公式アカウントの「チャネルシークレット」もプロパティ化
const LINE_CHANNEL_SECRET = getRequiredScriptProperty('LINE_CHANNEL_SECRET');

// 2. 予約台帳シートが入っているスプレッドシートのID
const YOYAKU_SS_ID = getRequiredScriptProperty('YOYAKU_SS_ID'); // ※名簿やチャットと同じであればそのままでOK
const YOYAKU_SHEET_NAME = '予約台帳';

// 3. 住民名簿シートが入っているスプレッドシートのID（アップロードされた「LINEto名簿-北浅井」のID）
const MEIBO_SS_ID = getRequiredScriptProperty('MEIBO_SS_ID'); // ※お使いの名簿スプレッドシートIDをここに記述
const MEIBO_SHEET_NAME = '名簿';

// 4. チャットログ（履歴）を保存するスプレッドシートのID
const CHAT_SS_ID = getRequiredScriptProperty('CHAT_SS_ID');
const CHAT_SHEET_NAME = 'chat';

/**
 * 💡 Googleの認証を強制的にパスさせるための特殊アノテーション
 * @OnlyCurrentDoc
 * @filter
 * @OAuthScope https://www.googleapis.com/auth/spreadsheets
 * @OAuthScope https://www.googleapis.com/auth/script.external_request
 */

function getRequiredScriptProperty(key) {
  const value = PropertiesService.getScriptProperties().getProperty(key);
  if (!value) {
    throw new Error('Script property "' + key + '" is not set.');
  }
  return value.trim();
}

// ====================================================================
// 1. GETリクエスト（カレンダー、LIFFアプリ用の空き状況データ取得）
// ====================================================================
function doGet(e) {
  // --- 🌟 追加された住民名簿チェック処理 🌟 ---
  if (e && e.parameter && e.parameter.type === "user" && e.parameter.uid) {
    const uid = e.parameter.uid.toString().trim(); // フロントから送られてきたIDをトリム
    
    try {
      const meiboSS = SpreadsheetApp.openById(MEIBO_SS_ID);
      const mSheet = meiboSS.getSheetByName('名簿');
      const mData = mSheet.getDataRange().getValues();
      const header = mData[0];
      
      // 1. ヘッダー名に含まれるスペースや改行を自動でトリムして小文字化
      const cleanHeader = header.map(h => h.toString().trim().toLowerCase());
      
      // 2. インデックスの検索（これで前後にスペースがあっても見逃しません）
      const idCol = cleanHeader.indexOf("line_id");
      const lastNameCol = cleanHeader.indexOf("name_2nd");
      const firstNameCol = cleanHeader.indexOf("name_1st");
      const statusCol = cleanHeader.indexOf("status"); // status列
      
      if (idCol === -1) {
        console.error("❌ 名簿シートに「line_id」列が見つかりません。");
        return ContentService.createTextOutput(JSON.stringify({ isRegistered: false, error: "line_id column missing" }))
          .setMimeType(ContentService.MimeType.JSON);
      }
      
      // 3. 一致判定を trim() と小文字化を合わせて完全強化（ノイズがあっても一致させます）
      const row = mData.find(r => {
        if (!r[idCol]) return false;
        return r[idCol].toString().trim().toLowerCase() === uid.toLowerCase();
      });
      
      if (!row) {
        // 名簿に line_id が登録されていない場合
        console.warn("⚠️ line_id: " + uid + " は名簿データ内に見つかりませんでした。");
        return ContentService.createTextOutput(JSON.stringify({ isRegistered: false }))
          .setMimeType(ContentService.MimeType.JSON);
      }
      
      const fullName = (row[lastNameCol] || "") + " " + (row[firstNameCol] || "");
      const status = row[statusCol] ? row[statusCol].toString().trim().toUpperCase() : "OK";
      
      // 照合成功
      console.log("🟢 合致しました: " + fullName + " (" + status + ")");
      return ContentService.createTextOutput(JSON.stringify({
        isRegistered: true,
        fullName: fullName.trim(),
        status: status // "OK" または "NG"
      })).setMimeType(ContentService.MimeType.JSON);
      
    } catch(err) {
      console.error("名簿判定エラー: " + err.toString());
      return ContentService.createTextOutput(JSON.stringify({ isRegistered: true, fullName: "通信エラー", status: "OK" }))
        .setMimeType(ContentService.MimeType.JSON);
    }
  }
  
  // --- 📅 従来の予約一覧を取得する処理 (変更なし) ---
  const sheet = SpreadsheetApp.openById(YOYAKU_SS_ID).getSheetByName(YOYAKU_SHEET_NAME);
  const data = sheet.getDataRange().getValues();
  
  const reservations = [];
  for (let i = 1; i < data.length; i++) {
    const status = data[i][7];
    if (status === "確定" || status === "保留") { 
      reservations.push({
        date: Utilities.formatDate(new Date(data[i][3]), "JST", "yyyy-MM-dd"),
        time_slot: data[i][4],
        room: data[i][5],
        line_id: data[i][1],
        name: data[i][2],
        status: status
      });
    }
  }
  return ContentService.createTextOutput(JSON.stringify(reservations))
    .setMimeType(ContentService.MimeType.JSON);
}


// ====================================================================
// 2. POSTリクエスト（LIFFからの新規予約、およびLINE Webhookの分岐処理）
// ====================================================================
function doPost(e) {
  try {
    const bodyString = e && e.postData && e.postData.contents ? e.postData.contents : "{}";
    const postData = JSON.parse(bodyString);
    
    // A. LINEからのWebhookシグナル（テキストメッセージ、または管理者の承認ポストバック）
    if (postData.events) {
      const signature = getLineSignatureFromEvent(e);
      if (!validateSignature(bodyString, signature)) {
        return ContentService.createTextOutput(JSON.stringify({ result: "unauthorized" }))
          .setMimeType(ContentService.MimeType.JSON);
      }
      return handleLineWebhook(postData.events);
    } else {
      // B. 住民用のLIFF予約フォームから直接送られてきた新規申請
      if (!verifyLiffToken(postData.liff_token)) {
        return ContentService.createTextOutput(JSON.stringify({ status: "error", message: "invalid liff token" }))
          .setMimeType(ContentService.MimeType.JSON);
      }
      return handleLiffSubmission(postData);
    }
  } catch(error) {
    return ContentService.createTextOutput(JSON.stringify({ status: "error", message: error.toString() }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

// --------------------------------------------------------------------
// A-1. LINE Webhookのイベントをスマートに仕分ける
// --------------------------------------------------------------------
function handleLineWebhook(events) {
  const chatRows = [];

  events.forEach(event => {
    // 【仕分け1】一般のテキストメッセージ受信 ➔ チャット履歴に保存
    if (event.type === 'message' && event.message.type === 'text') {
      const userId = event.source.userId;
      const messageText = event.message.text;
      const timestamp = new Date(event.timestamp);
      
      // 名簿またはLINE Profile APIから本名・表示名を取得
      const memberInfo = getMemberInfo(userId);
      const displayName = memberInfo && memberInfo.fullName ? memberInfo.fullName : getLineDisplayName(userId);

      chatRows.push([
        Utilities.formatDate(timestamp, "JST", "yyyy/MM/dd HH:mm:ss"), // 日本時間
        displayName,
        messageText,
        userId
      ]);
    }
    
    // 【仕分け2】管理者のFlex Message内「承認」「差し戻し」ボタンタップ処理
    if (event.type === "postback") {
      processPostbackApproval(event);
    }
  });

  // チャットログがあれば「chat」シートにまとめて書き込む
  if (chatRows.length > 0) {
    const ss = SpreadsheetApp.openById(CHAT_SS_ID);
    const sheet = ss.getSheetByName(CHAT_SHEET_NAME) || ss.insertSheet(CHAT_SHEET_NAME);
    
    if (sheet.getLastRow() < 1 || sheet.getRange('A1').getValue() !== 'created_at') {
      sheet.clear();
      sheet.appendRow(['created_at', 'line_name', 'message', 'line_id']);
    }
    sheet.getRange(sheet.getLastRow() + 1, 1, chatRows.length, chatRows[0].length).setValues(chatRows);
  }

  return ContentService.createTextOutput('{"result": "ok"}').setMimeType(ContentService.MimeType.JSON);
}

// --------------------------------------------------------------------
// A-2. 管理者の承認ポストバック処理
// --------------------------------------------------------------------
function processPostbackApproval(event) {
  const replyToken = event.replyToken;
  const adminUserId = event.source.userId;
  
  // ポストバックデータのパース
  const params = {};
  event.postback.data.split("&").forEach(pair => {
    const parts = pair.split("=");
    params[parts[0]] = decodeURIComponent(parts[1]);
  });
  
  const sheet = SpreadsheetApp.openById(YOYAKU_SS_ID).getSheetByName(YOYAKU_SHEET_NAME);
  const rowNum = parseInt(params.row);
  
  // 承認ステータス確認
  const currentStatus = sheet.getRange(rowNum, 8).getValue(); // H列(status)
  if (currentStatus !== "保留") {
    replyLineMessage(replyToken, "⚠️ 予約申請（No." + rowNum + "）はすでに処理済みです。現在の状態: 「" + currentStatus + "」");
    return;
  }
  
  const applicantId = params.applicant;
  const reqDate = params.date;
  const reqRoom = params.room;
  const reqSlot = params.slot;

  if (params.action === "approve") {
    // 承認確定
    sheet.getRange(rowNum, 8).setValue("確定");
    
    const successMsg = "🎉【北浅井公民館】予約確定のお知らせ\n\nご申請いただいておりました公民館の予約が、管理者により【承認】されました！\n当日のお越しをお待ちしております。\n\n" +
                       "■施設: " + reqRoom + "\n" +
                       "■日付: " + reqDate + "\n" +
                       "■時間帯: " + reqSlot;
    sendLineTextMessage(applicantId, successMsg);
    replyLineMessage(replyToken, "✅ 予約申請（No." + rowNum + "）を【承認】しました。申請者に確定通知を送信しました。");

  } else if (params.action === "reject") {
    // 却下（差し戻し）
    sheet.getRange(rowNum, 8).setValue("却下");
    
    const failMsg = "⚠️【北浅井公民館】予約差し戻しのお知らせ\n\nご申請いただいておりました公民館の予約は、スケジュール重複等の理由により【却下】となりました。\n大変恐縮ですが、別の日程または施設をご検討ください。\n\n" +
                    "■施設: " + reqRoom + "\n" +
                    "■日付: " + reqDate + "\n" +
                    "■時間帯: " + reqSlot;
    sendLineTextMessage(applicantId, failMsg);
    replyLineMessage(replyToken, "❌ 予約申請（No." + rowNum + "）を【却下（差し戻し）】しました。申請者に通知を送信しました。");
  }
}

// --------------------------------------------------------------------
// B. LIFFからの新規予約申請処理（スプレッドシートへ「保留」として追記）
// --------------------------------------------------------------------
function handleLiffSubmission(params) {
  const sheet = SpreadsheetApp.openById(YOYAKU_SS_ID).getSheetByName(YOYAKU_SHEET_NAME);
  const data = sheet.getDataRange().getValues();
  
  for (let i = 1; i < data.length; i++) {
    const rowDate = Utilities.formatDate(new Date(data[i][3]), "JST", "yyyy-MM-dd");
    const status = data[i][7];
    if (rowDate === params.date && data[i][4] === params.time_slot && data[i][5] === params.room && (status === "確定" || status === "保留")) {
      return ContentService.createTextOutput(JSON.stringify({ status: "error", message: "すでに対象の時間帯は予約または申請が入っています。" }))
        .setMimeType(ContentService.MimeType.JSON);
    }
  }
  
  const memberInfo = getMemberInfo(params.line_id);
  let realName = memberInfo && memberInfo.fullName ? memberInfo.fullName : params.line_name;

  sheet.appendRow([
    new Date(),          
    params.line_id,      
    realName,            
    params.date,         
    params.time_slot,    
    params.room,         
    params.request || "",
    "保留"               
  ]);
  
  const insertedRow = sheet.getLastRow();
  const requestText = (params.request || "").toString().trim() || "なし";

  // 1. 申請者本人へ受付完了プッシュメッセージ送信
  const userMsg = "【北浅井公民館】\n予約の申請を受け付けました。\n現在、管理者による確認を行っております。確定するまで今しばらくお待ちください。\n\n" +
                  "■施設: " + params.room + "\n" +
                  "■日付: " + params.date + "\n" +
                  "■時間帯: " + params.time_slot + "\n" +
                  "■ご要望: " + requestText + "\n\n" +
                  "※審査結果は本チャットにて自動でお知らせします。";
  sendLineTextMessage(params.line_id, userMsg);

  // 2. 「alert」列が「bookroom」の管理者へFlex承認ボタン付き通知を送信
  const admins = getAdmins();
  if (admins.length > 0) {
    sendAdminFlexApproval(admins, {
      row: insertedRow,
      applicantId: params.line_id,
      applicantName: realName,
      date: params.date,
      room: params.room,

      
      time_slot: params.time_slot,
      request: requestText
    });
  }

  return ContentService.createTextOutput(JSON.stringify({ status: "success" }))
    .setMimeType(ContentService.MimeType.JSON);
}

// ====================================================================
// 共通のデータ処理・LINE通信用ヘルパー関数群
// ====================================================================

// 住民名簿シートから本名（姓 名）を取得する
function getMemberInfo(uid) {
  if (!uid) return null;
  try {
    const meiboSS = SpreadsheetApp.openById(MEIBO_SS_ID);
    const mSheet = meiboSS.getSheetByName(MEIBO_SHEET_NAME);
    const mData = mSheet.getDataRange().getValues();
    const header = mData[0];
    
    const idCol = header.indexOf("line_id");
    const lastNameCol = header.indexOf("name_2nd");
    const firstNameCol = header.indexOf("name_1st");

    const row = mData.find(r => r[idCol] === uid);
    if (!row) return null;

    return {
      fullName: row[lastNameCol] + " " + row[firstNameCol]
    };
  } catch (e) {
    return null;
  }
}

// アラート管理者の line_id リストを取得する
function getAdmins() {
  try {
    const meiboSS = SpreadsheetApp.openById(MEIBO_SS_ID);
    const mSheet = meiboSS.getSheetByName(MEIBO_SHEET_NAME);
    const mData = mSheet.getDataRange().getValues();
    const header = mData[0];
    
    const idCol = header.indexOf("line_id");
    const alertCol = header.indexOf("alert");
    
    const admins = [];
    for (let i = 1; i < mData.length; i++) {
      const row = mData[i];
      if (row[alertCol] && row[idCol]) {
        const alertList = row[alertCol].toString().split(",").map(item => item.trim());
        if (alertList.includes("bookroom")) {
          admins.push(row[idCol].toString());
        }
      }
    }
    return admins;
  } catch(e) {
    console.error("管理者取得エラー: " + e.toString());
    return [];
  }
}

// LINE Profile APIから表示名を取得
function getLineDisplayName(userId) {
  const profileUrl = `https://api.line.me/v2/bot/profile/${userId}`;
  const options = {
    'method': 'get',
    'headers': {
      'Authorization': `Bearer ${LINE_CHANNEL_ACCESS_TOKEN}`
    },
    'muteHttpExceptions': true
  };
  try {
    const response = UrlFetchApp.fetch(profileUrl, options);
    const profile = JSON.parse(response.getContentText());
    if (profile && profile.displayName) {
      return profile.displayName;
    }
  } catch (e) {
    Logger.log(`Failed to fetch profile: ${e.toString()}`);
  }
  return `ID:${userId}`; 
}

