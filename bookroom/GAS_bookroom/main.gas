// 汎用プッシュメッセージ
function sendLineTextMessage(targetId, text) {
  const url = "https://api.line.me/v2/bot/message/push";
  const payload = {
    "to": targetId,
    "messages": [{ "type": "text", "text": text }]
  };
  const options = {
    "method": "post",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + LINE_CHANNEL_ACCESS_TOKEN
    },
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };
  UrlFetchApp.fetch(url, options);
}

// Webhook応答用
function replyLineMessage(replyToken, text) {
  const url = "https://api.line.me/v2/bot/message/reply";
  const payload = {
    "replyToken": replyToken,
    "messages": [{ "type": "text", "text": text }]
  };
  const options = {
    "method": "post",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + LINE_CHANNEL_ACCESS_TOKEN
    },
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };
  UrlFetchApp.fetch(url, options);
}

function getLineSignatureFromEvent(e) {
  if (!e) return "";

  const candidates = [];

  if (e.headers) {
    candidates.push(e.headers['X-Line-Signature']);
    candidates.push(e.headers['x-line-signature']);
  }

  if (e.parameter) {
    candidates.push(e.parameter['X-Line-Signature']);
    candidates.push(e.parameter['x-line-signature']);
  }

  if (e.parameters) {
    const upper = e.parameters['X-Line-Signature'];
    const lower = e.parameters['x-line-signature'];
    if (upper && upper.length > 0) candidates.push(upper[0]);
    if (lower && lower.length > 0) candidates.push(lower[0]);
  }

  const signature = candidates.find(v => v && v.toString().trim());
  return signature ? signature.toString().trim() : "";
}

function validateSignature(bodyString, signature) {
  if (!bodyString || !signature) return false;

  const raw = Utilities.computeHmacSignature(
    Utilities.MacAlgorithm.HMAC_SHA_256,
    bodyString,
    LINE_CHANNEL_SECRET
  );
  const expected = Utilities.base64Encode(raw);
  return expected === signature;
}

function verifyLiffToken(token) {
  if (!token) return false;

  try {
    const verifyUrl = "https://api.line.me/oauth2/v2.1/verify?access_token=" + encodeURIComponent(token);
    const response = UrlFetchApp.fetch(verifyUrl, {
      method: "get",
      muteHttpExceptions: true
    });

    if (response.getResponseCode() !== 200) return false;

    const result = JSON.parse(response.getContentText() || "{}");
    if (!result.client_id) return false;
    if (result.expires_in !== undefined && Number(result.expires_in) <= 0) return false;

    return true;
  } catch (err) {
    console.error("LIFF token verification error: " + err.toString());
    return false;
  }
}

// ====================================================================
// 🛑【エラー対策】認証を強制的に起動するための使い捨て関数
// ====================================================================
function triggerAuthorization() {
  try {
    UrlFetchApp.getRequest("https://api.line.me/");
  } catch(e) {}
  Logger.log("無事に認証が完了しました！");
}