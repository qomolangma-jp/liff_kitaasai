      ]
    },
    "footer": {
      "type": "box",
      "layout": "horizontal",
      "spacing": "md",
      "contents": [
        {
          "type": "button",
          "style": "primary",
          "color": "#16a34a",
          "height": "sm",
          "action": {
            "type": "postback",
            "label": "承認（確定）",
            "data": "action=approve&row=" + info.row + "&applicant=" + info.applicantId + "&date=" + info.date + "&room=" + rName + "&slot=" + sName
          }
        },
        {
          "type": "button",
