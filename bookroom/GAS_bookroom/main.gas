          "wrap": true,
          "size": "sm",
          "color": "#444444"
        },
        {
          "type": "box",
          "layout": "vertical",
          "backgroundColor": "#f8fafc",
          "paddingAll": "md",
          "cornerRadius": "md",
          "contents": [
            {
              "type": "box",
              "layout": "horizontal",
              "contents": [
                { "type": "text", "text": "申請者", "color": "#94a3b8", "size": "xs", "flex": 2, "weight": "bold" },
                { "type": "text", "text": info.applicantName + " 様", "color": "#1e293b", "size": "xs", "flex": 5, "weight": "bold" }
              ]
            },
            {
              "type": "box",
              "layout": "horizontal",
              "margin": "sm",
              "contents": [
                { "type": "text", "text": "利用施設", "color": "#94a3b8", "size": "xs", "flex": 2, "weight": "bold" },
                { "type": "text", "text": info.room, "color": "#1e293b", "size": "xs", "flex": 5 }
              ]
            },
            {
              "type": "box",
              "layout": "horizontal",
              "margin": "sm",
              "contents": [
                { "type": "text", "text": "利用日", "color": "#94a3b8", "size": "xs", "flex": 2, "weight": "bold" },
                { "type": "text", "text": info.date, "color": "#1e293b", "size": "xs", "flex": 5 }
              ]
            },
            {
              "type": "box",
              "layout": "horizontal",
              "margin": "sm",
              "contents": [
                { "type": "text", "text": "時間帯", "color": "#94a3b8", "size": "xs", "flex": 2, "weight": "bold" },
                { "type": "text", "text": info.time_slot, "color": "#1e293b", "size": "xs", "flex": 5 }
              ]
            },
            {
              "type": "box",
              "layout": "horizontal",
              "margin": "sm",
              "contents": [
                { "type": "text", "text": "ご要望", "color": "#94a3b8", "size": "xs", "flex": 2, "weight": "bold" },
                { "type": "text", "text": requestText, "color": "#1e293b", "size": "xs", "flex": 5, "wrap": true }
              ]
            }
          ]
